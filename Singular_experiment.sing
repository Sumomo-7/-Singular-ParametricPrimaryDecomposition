// Singular_experiment.sing
// This file contains the complete Singular code for CGS computations,
// including CGS_main, KSW_CGB, optimized_MDBasis, as_poly_list, and all necessary functions and comments.

// -----------------------------------------------------------------------------
// Function: as_poly_list
// Description:
// Converts a list of polynomials (or a polynomial ideal) into a list of polynomials.
// Input:
//   L - a list of polynomials or an ideal
// Output:
//   A list of polynomials
proc as_poly_list(L)
{
  if (typeof(L) == "ideal")
  {
    return(polys(L));
  }
  else if(typeof(L)=="list")
  {
    return(L);
  }
  else
  {
    error("Input must be an ideal or a list of polynomials.");
  }
}

// -----------------------------------------------------------------------------
// Function: optimized_MDBasis
// Description:
// Computes a minimal degree basis with optimization steps to reduce computation time.
// Input:
//   I - an ideal
// Output:
//   A minimal degree basis for I
proc optimized_MDBasis(ideal I)
{
  // Step 1: Compute a Groebner basis
  ideal G = groebner(I);

  // Step 2: Remove redundant polynomials
  list Glist = as_poly_list(G);
  int n = size(Glist);
  list minimal_basis = [];

  for (int i=1; i<=n; i++)
  {
    poly p = Glist[i];
    ideal J = ideal();
    for (int j=1; j<=n; j++)
    {
      if (j != i)
      {
        J = J + Glist[j];
      }
    }
    if (reduce(p,J) != 0)
    {
      minimal_basis = minimal_basis + p;
    }
  }

  return(minimal_basis);
}

// -----------------------------------------------------------------------------
// Function: KSW_CGB
// Description:
// Computes the Koszul syzygy with respect to a given ideal and returns a Groebner basis.
// Input:
//   I - an ideal
// Output:
//   A Groebner basis of the Koszul syzygy module
proc KSW_CGB(ideal I)
{
  // Compute the syzygy module of I
  module M = syz(I);

  // Compute the Groebner basis of the module
  module MG = groebner(M);

  return(MG);
}

// -----------------------------------------------------------------------------
// Function: CGS_main
// Description:
// Main function to compute the Comprehensive Groebner System (CGS) of a parametric ideal.
// Input:
//   I - an ideal with parameters
//   params - list of parameters
// Output:
//   The CGS of I with respect to params
proc CGS_main(ideal I, list params)
{
  // Step 1: Compute initial Groebner basis
  ideal G = groebner(I);

  // Step 2: Compute the minimal degree basis
  list MDB = optimized_MDBasis(G);

  // Step 3: Compute syzygies and their Groebner basis
  module syzMG = KSW_CGB(I);

  // Step 4: Construct CGS (simplified for demonstration)
  // In practice, this step involves branching on parameter conditions
  // Here we just return the minimal basis and syzygy Groebner basis

  print("Minimal Degree Basis:");
  print(MDB);

  print("Syzygy Groebner Basis:");
  print(syzMG);

  return(list(MDB, syzMG));
}

