LIB "primdec.lib";

static proc list2string(list L){
    //数学的な意味を持たない。
    int i;
    string s = "";

    for(i=1; i<=size(L); i++){
        if(i>1){
            s = s + ",";
        }
        s = s + string(L[i]);
    }
    return(s);
}

static proc makering1(string ringName, list XUX, list AUA, list U){
    //makering関数は全員数学的に大した意味を持たない。ただSingularでの環創成がlistに弱いのでその迂回策
    //ring ringName = 0, (XUX, AUA, U), (dp(size(XUX)), dp(size(AUA)), dp(size(U)));
    string sX = list2string(XUX);
    string sA = list2string(AUA);
    string sU = list2string(U);

    string allvars = "";

    if(size(XUX)>0){
        allvars = sX;
    }

    if(size(AUA)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sA;
    }

    if(size(U)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sU;
    }

    string Ord = "(";

    if(size(XUX)>0){
        Ord = Ord + "dp(" + string(size(XUX)) + ")";
    }

    if(size(AUA)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }

        Ord = Ord + "dp(" + string(size(AUA)) + ")";
    }

    if(size(U)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }
        Ord = Ord + "dp(" + string(size(U)) + ")";
    }

    Ord = Ord + ")";

    string cmd ="ring " + ringName + " = 0,(" + allvars + ")," + Ord + ";";
    
    return(cmd);
}

static proc makering1lp(string ringName, list XUX, list AUA, list U){
    //ring ringName = 0, (XUX, AUA, U), (lp(size(XUX)), lp(size(AUA)), lp(size(U)));
    string sX = list2string(XUX);
    string sA = list2string(AUA);
    string sU = list2string(U);

    string allvars = "";

    if(size(XUX)>0){
        allvars = sX;
    }

    if(size(AUA)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sA;
    }

    if(size(U)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sU;
    }

    string Ord = "(";

    if(size(XUX)>0){
        Ord = Ord + "lp(" + string(size(XUX)) + ")";
    }

    if(size(AUA)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }

        Ord = Ord + "lp(" + string(size(AUA)) + ")";
    }

    if(size(U)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }
        Ord = Ord + "lp(" + string(size(U)) + ")";
    }

    Ord = Ord + ")";

    string cmd ="ring " + ringName + " = 0,(" + allvars + ")," + Ord + ";";
    
    return(cmd);
}

static proc makering2(string ringName, list XUX, list AUA, list U){
    //ring ringName = (0, U), (XUX, AUA), (dp(size(XUX)), dp(size(AUA)));
    string sX = list2string(XUX);
    string sA = list2string(AUA);
    string sU = list2string(U);

    string vars = "";

    if(size(XUX)>0){
        vars = sX;
    }

    if(size(AUA)>0){
        if(size(vars)>0){
            vars = vars + ",";
        }

        vars = vars + sA;
    }

    string ord = "(";

    if(size(XUX)>0){
        ord = ord + "dp(" + string(size(XUX)) + ")";
    }

    if(size(AUA)>0){
        if(ord != "("){
            ord = ord + ",";
        }

        ord = ord + "dp(" + string(size(AUA)) + ")";
    }

    ord = ord + ")";

    string cmd =
        "ring " + ringName
        + " = (0,"
        + "(" + sU + ")),"
        + "(" + vars + "),"
        + ord
        + ";";

    return(cmd);
}

static proc makering3(string ringName, list XUX, list AUA, list U){
    //ring ringName = (0, AUA, U), XUX, dp;
    string sX = list2string(XUX);
    string sA = list2string(AUA);
    string sU = list2string(U);

    string params = "";

    if(size(AUA)>0){
        params = sA;
    }

    if(size(U)>0){
        if(size(params)>0){
            params = params + ",";
        }

        params = params + sU;
    }

    string cmd =
        "ring " + ringName
        + " = (0,"
        + "(" + params + ")),"
        + "(" + sX + "),dp;";

    return(cmd);
}


proc ext_shape(ideal varP){
    //K[A, X]上の素イデアルPが与えられるとする。
    //list Varが変数とパラメータリスト{X, A}である。
    //事前に最小変数VMinDPolyと多項式環RingAllがexportされているとする。
    //[Y.Ishihara, K.Yokoyama]Lemma12, Remark8によるshape form(とgeneric minimal polynomial)の計算
    setring(RingAll);
    ideal P = imap(RingVar, varP);
    list Var = imap(RingVar, Indeterminates);
    int i;

    intvec U = indepSet(P);
    list XUX, AUA, varU;

    for (i = 1; i <= size(U); i++){
        if (U[i] == 0){
            if (Var[i] < VMinDPoly){
                AUA[size(AUA)+1] = Var[i];
            }
            else{
                XUX[size(XUX)+1] = Var[i];
            }
        }else{
            varU[size(varU)+1] = Var[i];
        }
    }
    poly tempXr = XUX[size(XUX)];

    string Cmd = makering1lp("RingShape", XUX, AUA, varU);
    execute(Cmd);
    poly Xr = imap(RingAll, tempXr);

    ideal P_ext = imap(RingAll, P);
    //これでPがK(AUA,varU)[XUX]へ拡大されたと考えられる。
    ideal G = std(P_ext);
    //［優先度低い］ほとんどの場合このGroebner基底がそのままShape formになるが、まれにそうでもなく、線形変換が必要になることがある。その対応が必要である。
    //対応法として、[野呂・横山]アルゴリズム4.9, 4.30などを参照。Lex順序に関するGroebner基底がShape formでない場合、ランダムに線形変数変換を施した後、独立に最小多項式を求めて、そのminimal polynomialでShape formが求まる。この場合Groebner基底w.r.t.lpで一気に両方を出すことは無理。
    list PQ_shape;
    poly f_shape;

    for(i=1; i<=size(G); i++){
        if(variables(G[i])[1] != Xr){
            PQ_shape[size(PQ_shape)+1] = G[i];
        }else{
            f_shape = G[i];
        }
    }
    int flag = 0;
    if(size(PQ_shape)){
        flag = 1;
    }

    setring(RingVar);
    
    poly lcPlcQ = 1;
    if(flag){
        list PQ = imap(RingShape, PQ_shape);
    }else{
        list PQ = list();
    }
    poly f = imap(RingShape, f_shape);

    for(i=1; i<=size(PQ); i++){
        lcPlcQ = lcPlcQ * leadcoef(PQ[i]);
        if(PQ[i]-lead(PQ[i]) != 0){
            //そのままq_i == 0 になることもあるから、0がかけられたら困るのでIF文を入れる。
            lcPlcQ = lcPlcQ * leadcoef(PQ[i]-lead(PQ[i]));
        }
    }
    return(lcPlcQ, f);
}

proc paraprimdec(ideal F, list Paras, list Vars, list Indet,def RingVar, def RingAll){
    //イデアルFがRingVarの下で与えられたと仮定する。
    option(redSB);
    option(noredefine);
    int i, j;
    
    list Parameters = Paras;
    list Variables = Vars;
    list Indeterminates = Indet;
    poly VMinDPoly_var = Vars[size(Vars)];
    list Checks = 0, 0, 0, 0, 0, 0;

    export(Parameters, Variables, Indeterminates, VMinDPoly_var, Checks);
    export(RingVar, RingAll);

    list Z = list();

    ideal G = std(F);
    list PD = primdecSY(G);
    list N = list();

    //準素成分Q_iの先頭係数積を集める。Gの先頭係数がこれらに含まれるはずなので別に集める必要はない。
    for(i=1; i<=size(PD); i++){
        poly h = 1;
        for(j=1; j<=size(PD[i][1]); j++){
            h = h * leadcoef(PD[i][1][j]);
        }
        if(h != 1){
            N[size(N)+1] = h;
        }
    }

    setring(RingAll);
    poly VMinDPoly = imap(RingVar, VMinDPoly_var);
    export(VMinDPoly, Checks);

    ideal F_all = imap(RingVar, F);
    ideal G_all = imap(RingVar, G);
    poly h_all = imap(RingVar, h);
    
    //S \intersect K[A]の計算
    ideal S = quotient(F_all, G_all);

    list SA;
    for (i=1; i<=size(S); i++){
        if(S[i]<VMinDPoly){
            SA[size(SA)+1] = S[i];
        }
    }
    //list J1：拡大されたPのShape formのパラメータ部分の積、list J2：Pの先頭係数積の計算、Of：K[A, X]上の既約多項式集合、efficient HITにて特化イデアルの準素判定に登場
    setring(RingVar);

    list J1, J2;
    list Of;
    for(i=1; i<=size(PD); i++){//Q_iの先頭項も併せてここで入れた方が効率的かも、再帰呼び出しを簡単にするためあえて別々でする。
        ideal P = PD[i][2];
        poly h = 1;
        for(j=1; j<=size(P); j++){
            h = h * leadcoef(P[j]);
        }
        if(h != 1){
            J2[size(J2)+1] = h;
        }
        J1[size(J1)+1], Of[size(Of)+1] = ext_shape(P);
    }
    ideal E = 0;
    //Conbine list SA_var, list J1, J2, list N={h1, ..., hm}, note that elements in {h1, ..., hm} + SA_var will be used in the next step of computing CGS. 
    list SA_var = imap(RingAll, SA);
    for(i=1; i<=size(SA_var); i++){
        if(SA_var[i] != 1){
            N[size(N)+1] = SA_var[i];
        }
    }

    int m = size(N);
    //再帰呼び出しではN[1]~N[m]を呼び出す。

    list J;
    poly tempf = 1;
    for(i=1; i<=size(J1); i++){
        tempf = tempf * J1[i];
    }
    J[size(J)+1] = tempf;

    poly tempf = 1;
    for(i=1; i<=size(J2); i++){
        tempf = tempf * J2[i];
    }
    J[size(J)+1] = tempf;

    for(i=1; i<=size(J); i++){
        if(J[i] != 1){
            int not_redundant = 1;
            for(j=1; j<=size(N); j++){
                if(N[j] == J[i]){
                    not_redundant = 0;
                    break;
                }
            }
            if(not_redundant){
                N[size(N)+1] = J[i];
            }
        }
    }
    
    Z[size(Z)+1] = list(PD, E, N, Of);

    for(i=1; i<=m; i++){
        poly temph = N[i];

        setring(RingAll);
        ideal cgsE = imap(RingVar, temph);
        list cgsN = imap(RingVar, N);
        cgsN = delete(cgsN, i);
        ideal cgsF = imap(RingVar, F);

        list CGS = idealcgs_main(cgsE, cgsN, cgsF);
        //idealcgsはRingAll上のものを返す。その整合性を保て。
        for(j=1; j<=size(CGS); j++){
            Z[size(Z)+1] = PPD_main();
        }
    }
    setring(RingVar);
    return(Z);
}

/////Comprehensive Groebner System/////
static proc Radical_Equ(ideal Equ){
//From KSW. Eの元を因数分解して無平方化しただけ。できるだけ遅いとされる根基を避けている本アルゴリズムでは初手で根基を計算するわけがない。
    if (size(Equ) == 0){
        return(Equ);
  }
  ideal SqrEqu;
  list EquFactors;
  poly tempP;
  int i, j, flag;
  
  for (i = 1; i <= size(Equ); i++){
    
    EquFactors = factorize(Equ[i], 2);

    flag = 0;
    for (j = 1; j <= size(EquFactors[2]); j++){
      if (EquFactors[2][j] > 1){
        flag = 1;
        break;
      }
    }
    if (flag){
      tempP = 1;
      for (j = 1; j <= size(EquFactors[1]); j++){
        tempP = tempP * EquFactors[1][j];
      }
      SqrEqu = SqrEqu + tempP;
    }
  }

  if (size(SqrEqu)){
    return(std(Equ + SqrEqu));
  }
  else{
    return(Equ);
  }
}

static proc Simplify_DisEqu(list DisEqu, ideal Equ){
    //From KSW. Nを因数分解してEでそれらを簡約化した。Simplifyというより矛盾する条件を事前に取り除いている。
    list newDisEqu;
    ideal DisFactors;
    poly tempP;
    int i, j, k, flag;

    for (i = 1; i <= size(DisEqu); i++){
        DisFactors = factorize(DisEqu[i], 1);
        for (j = 1; j <= size(DisFactors); j++){
            if (size(Equ)){
                tempP = reduce(DisFactors[j], Equ);
            }else{
                tempP = DisFactors[j];
            }
            if (leadmonom(tempP) != 1){
                flag = 1;
                for (k = 1; k <= size(newDisEqu); k++){
                    if (newDisEqu[k] == tempP){
                        flag = 0;
                        break;
                    }
                }
                if (flag){
                    newDisEqu[size(newDisEqu)+1] = tempP;
                }
            }
        }
    }
    return(newDisEqu);
}

static proc Simplify_Equ(ideal Equ, list DisEqu){
    //From KSW. 余計にエラーを引き起こす可能性がある？？？：EをNの簡単な形を持つ元、i.e. 次数が3以下か単項式の数が5以下のもので簡約する。
    if (size(Equ) == 0){
        return(Equ);
    }
    if (Equ[1] == 1){
        return(Equ);
    }
    ideal newEqu, tempGB;
    int i, j;
    
    newEqu = Equ;

    for (i = 1; i <= size(DisEqu); i++){
        if ((deg(DisEqu[i]) > 3) || (size(DisEqu[i]) > 5)){
            i++;
            continue;
        }

        tempGB = std(newEqu + (DisEqu[i] * VMinDPoly - 1));
        if (tempGB[1] == 1){
            return(ideal(1)); //may incur error
        }

        newEqu = ideal();

        for (j = 1; j <= size(tempGB); j++){
            if (VMinDPoly > tempGB[j]){
                newEqu = newEqu + tempGB[j];
            }
        }
    }
    return(std(newEqu));
}

//Checks=[total, tri-check, 0dim-check, c-check, i-check, gen-check];
proc Check_Consistence(ideal Equ, list DisEqu){
    //From KSW. KSWアルゴリズムの真骨頂
    Checks[1] = Checks[1] + 1;
    //trivial checks
    if (!size(Equ)){
        Checks[2] = Checks[2] + 1;
        return(1);
    }
    if (Equ[1] == 1){
        Checks[2] = Checks[2] + 1;
        return(0);
    }
    if (!size(DisEqu)){
        Checks[2] = Checks[2] + 1;
        return(1);
    }
    //normal form
    poly DE = 1;
    int i, j;
    
    for (i = 1; i <= size(DisEqu); i++){
        DE = reduce(DE * DisEqu[i], Equ);
        if (DE == 0){
            //Nの一部がEに含まれることになるのでこの部分が必ず同時に「0になる」と「0にならない」ことが要求されて矛盾
            Checks[2] = Checks[2] + 1;
            return(0);
        }
    }
    //c-check
    int ctimes = 1;
    ideal LM;

    for (i = 1; i <= size(Equ); i++){
        LM = LM + leadmonom(Equ[i]);
    }
    LM = std(LM);
    intvec Indvec = indepSet(LM);
    
    list Indvar;
    for (i = size(Variables) + 1; i <= size(Indvec); i++){
        if (Indvec[i] != 0){
            Indvar = Indvar + list(Parameters[i - size(Variables)]);
        }
    }

    ideal tempGB, Spe;

    if (size(Indvar)){
        for (i = 1; i <= ctimes; i++){
            for (j = 1; j <= size(Indvar); j++){
                Spe = Spe + (Indvar[j] - random(-50, 50));
                //例えば(10, 20, 30)でパラメータ(a, b, c)を特化したいならば、イデアル<a-10, b-20, c-30>とEの和イデアルのGroebner基底を求めるといい。
            }
            
            tempGB = std(Equ + Spe + (DE * VMinDPoly - 1));

            if (tempGB[1] != 1){
                Checks[4] = Checks[4] + 1;
	        return(1);
            }
        }
    }
    //i-check
    int itimes = 3;
    poly newDE = DE;
    poly res, tempDE;
    tempGB = std(Equ);
    for (i = 1; i <= itimes; i++){
        if (size(newDE) > 20){
            break;
        }
        res = 0;
        tempDE = newDE;
        for (j = 1; j <= size(newDE); j++){
            res = res + reduce(lead(tempDE) * newDE, tempGB);
            tempDE = tempDE - lead(tempDE);
        }
        if (res == 0){
            Checks[5] = Checks[5] + 1;
            return(0);
        }
        newDE = res;
    }


  //general check
    tempGB = std(Equ + (DE * VMinDPoly - 1));
    if (tempGB[1] == 1){
        Checks[6] = Checks[6] + 1;
        return(0);
    }else{
        Checks[6] = Checks[6] + 1;
        return(1);
    }
}

proc idealcgs_main(ideal E, list N, ideal F){
    int i;
    ideal new_E = std(E);
    new_E = Radical_Equ(new_E);
    list new_N = Simplify_DisEqu(N, new_E);
    new_E = Simplify_Equ(new_E, new_N);
    //KSWのSによると、Simplify_Equがエラーを引き起こす可能性あるらしい。

    if (!Check_Consistence(new_E, new_N)){
        return(list());
    }

    ideal G = std(F + new_E);

    if (G[1] == 1){
        return(list(list(new_E, new_N, ideal(1))));
    }

    list Z = list();

    ideal GB;
    for(i = 1; i <= size(G); i++){
        if(G[i] > VMinDPoly){
            GB[size(GB)+1] = G[i];
        }
    }

    if (size(GB) == 0){
        return(list(list(new_E, new_N, ideal(0))));
    }

    ideal Gm;
    poly LCoefs;
    Gm, LCoefs = MDBasis(GB);
    list LCFactors;
    ideal tempLCFactors = factorize(LCoefs, 1);
    for(i=1; i<=size(tempLCFactors); i++){
        LCFactors[size(LCFactors)+1] = tempLCFactors[i];
    }

    if(Check_Consistence(new_E, new_N + LCFactors)){
        Z[size(Z)+1] = list(new_E, new_N + LCFactors, Gm);
    }

    list tempN = new_N;
    for(i = 1; i <= size(LCFactors); i++){
        ideal tempE = new_E;
        tempE[size(tempE)+1] = LCFactors[i];
        Z = Z + idealcgs_main(tempE, tempN, G);

        tempN[size(tempN)+1] = LCFactors[i];
    }
    return(Z);
}

proc MDBasis(G){
    int i, j, k, redundant;

    setring(RingVar);
    ideal G = imap(RingAll, G);
    poly LCoefs = 1;

    ideal lm_G;
    for(i=1; i<=size(G); i++){
        lm_G[size(lm_G)+1] = leadmonom(G[i]);
        LCoefs = LCoefs*leadcoef(G[i]);
    }

    setring(RingAll);
    ideal lm_G = imap(RingVar, lm_G);
    lm_G = std(lm_G);

    setring(RingVar);
    ideal lm_G = imap(RingAll, lm_G);

    ideal basis;
    for (i=1; i<=size(G); i++){
        for(j=1; j<=size(lm_G); j++){
            if(leadmonom(G[i]) == lm_G[j]){
                redundant = 0;
                for(k=1; k<=size(basis); k++){
                    if(leadmonom(basis[k]) == leadmonom(G[i])){
                        redundant = 1;
                        break;
                    }
                }
                if(redundant == 0){
                    basis[size(basis)+1] = G[i];
                }
            }
        }
    }
    setring(RingAll);
    return(imap(RingVar, basis), imap(RingVar, LCoefs));
}