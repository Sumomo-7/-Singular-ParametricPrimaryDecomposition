LIB "primdec.lib";
LIB "elim.lib";
LIB "polylib.lib";
LIB "/Users/ilumualf/Desktop/M2OS/codes/SingularCGS/primdecSYCI.lib";

static proc list2string(list L){
    //数学的な意味を持たない。
    int i;
    string s = "";
    for(i=1; i<=size(L); i++){
        if(i>1){
            s = s + ",";
        }
        s = s + string(L[i]);
    }
    return(s);
}

static proc makering1dp(string ringName, list XUX, list AUA, list U){
    //makering関数は全員数学的に大した意味を持たない。ただSingularでの環創成がlistに弱いのでその迂回策
    //ring ringName = 0, (XUX, AUA, U), (dp, dp, dp);
    string sX = list2string(XUX);
    string sA = list2string(AUA);
    string sU = list2string(U);

    string allvars = "";

    if(size(XUX)>0){
        allvars = sX;
    }

    if(size(AUA)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sA;
    }

    if(size(U)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sU;
    }

    string Ord = "(";

    if(size(XUX)>0){
        Ord = Ord + "dp(" + string(size(XUX)) + ")";
    }

    if(size(AUA)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }

        Ord = Ord + "dp(" + string(size(AUA)) + ")";
    }

    if(size(U)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }
        Ord = Ord + "dp(" + string(size(U)) + ")";
    }

    Ord = Ord + ")";

    string cmd ="ring " + ringName + " = 0,(" + allvars + ")," + Ord + ";";
    
    return(cmd);
}

static proc makering1lp(string ringName, list XUX, list AUA, list U){
    //ring ringName = 0, (XUX, AUA, U), (dp, lp, lp);
    string sX = list2string(XUX);
    string sA = list2string(AUA);
    string sU = list2string(U);

    string allvars = "";

    if(size(XUX)>0){
        allvars = sX;
    }

    if(size(AUA)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sA;
    }

    if(size(U)>0){
        if(size(allvars)>0){
            allvars = allvars + ",";
        }
        allvars = allvars + sU;
    }

    string Ord = "(";

    if(size(XUX)>0){
        Ord = Ord + "lp(" + string(size(XUX)) + ")";
    }

    if(size(AUA)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }

        Ord = Ord + "lp(" + string(size(AUA)) + ")";
    }

    if(size(U)>0){
        if(Ord != "("){
            Ord = Ord + ",";
        }
        Ord = Ord + "lp(" + string(size(U)) + ")";
    }

    Ord = Ord + ")";

    string cmd ="ring " + ringName + " = 0,(" + allvars + ")," + Ord + ";";
    
    return(cmd);
}

static proc makering2dp(string ringName, list XUX, list UX){
    //ring ringName = 0, (XUX, UX + A), (dp, dp);
    //the set of parameters Parameters_all has been exported globally.
    string sX = list2string(XUX);
    string sU = list2string(UX);
    string sA = list2string(Parameters_all);

    string tail = "";

    if(size(UX)>0){
        tail = sU;
    }
    if(size(Parameters_all)>0){
        if(size(tail)>0){
            tail = tail + ",";
        }
        tail = tail + sA;
    }

    string vars = sX;

    if(size(tail)>0){
        if(size(vars)>0){
            vars = vars + ",";
        }
        vars = vars + tail;
    }

    string Ord ="(dp(" + string(size(XUX)) + "),dp(" + string(size(UX)+size(Parameters_all)) + "))";

    string Cmd = "ring " + ringName + " = 0,(" + vars + ")," + Ord + ";";

    return(Cmd);
}

static proc makering2lp(string ringName, list XUX, list UX){
    //ring ringName = 0, (XUX, UX + A), (lp, lp);
    //the set of parameters Parameters_all has been exported globally.
    string sX = list2string(XUX);
    string sU = list2string(UX);
    string sA = list2string(Parameters_all);

    string tail = "";

    if(size(UX)>0){
        tail = sU;
    }
    if(size(Parameters_all)>0){
        if(size(tail)>0){
            tail = tail + ",";
        }
        tail = tail + sA;
    }

    string vars = sX;

    if(size(tail)>0){
        if(size(vars)>0){
            vars = vars + ",";
        }
        vars = vars + tail;
    }

    string Ord ="(lp(" + string(size(XUX)) + "),lp(" + string(size(UX)+size(Parameters_all)) + "))";

    string Cmd = "ring " + ringName + " = 0,(" + vars + ")," + Ord + ";";

    return(Cmd);
}

proc makering3dp(string ringName, list UX, list XUX){
    // ring ringName = (0, A, UX), XUX, dp;
    string sX = list2string(XUX);
    string sU = list2string(UX);
    string sA = list2string(Parameters_all);
    string sCoef = "0";
    
    if(size(Parameters_all)>0){
        sCoef = sCoef + ",";
        sCoef = sCoef + sA;
    }
    if(size(UX)>0){
        sCoef = sCoef + ",";
        sCoef = sCoef + sU;
    }

    string Cmd = "ring " + ringName + " = (" + sCoef + "), (" + sX + "), dp;";
    return(Cmd);
}

proc ext_shape(ideal varQ, ideal varP){
    //ただし与えられたvarPはK(A)[X]上の素イデアルのグレブナー基底である。
    //list Varが変数とパラメータリスト{X, A}である。
    //事前に最小変数VMinDPolyと多項式環RingAllがexportされているとする。
    //[Y.Ishihara, K.Yokoyama]Lemma12, Remark8によるshape form(とgeneric minimal polynomial)の計算
    int i, j;
    ideal tempLead;
    for(i=1; i<=size(varP); i++){
        tempLead[size(tempLead)+1] = leadmonom(varP[i]);
    }

    setring(RingAll);
    ideal lead_P = imap(RingVar, tempLead);
    list Var = imap(RingVar, Variables);

    intvec U = indepSet(lead_P);
    list XUX, UX;
    for (i = 1; i <= size(Var); i++){
        if (U[i] == 1){
            UX[size(UX)+1] = Var[i];
        }else{
            XUX[size(XUX)+1] = Var[i];
        }
    }

    poly tempXr = XUX[size(XUX)];

    string Cmd = makering3dp("RingSat", UX, XUX);
    execute(Cmd);

    ideal satQ, satP = imap(RingVar, varQ), imap(RingVar, varP);
    ideal tempLCQ, tempLCP;

    for(i=1; i<=size(satP); i++){
        tempLCP[size(tempLCP)+1] = leadcoef(satP[i]);
    }
    for(i=1; i<=size(satQ); i++){
        tempLCQ[size(tempLCQ)+1] = leadcoef(satQ[i]);
    }
    poly t1, t2 = lcm(tempLCP), lcm(tempLCQ);

    setring(RingAll);

    ideal H1 = sat(imap(RingVar, varP), imap(RingSat, t1))[1];
    ideal H2 = sat(imap(RingVar, varQ), imap(RingSat, t2))[1];

    ideal T1, T2;
    poly lcH1, lcH2;
    T1, lcH1 = MDBasis(H1);
    T2, lcH2 = MDBasis(H2);
    kill(T1);
    kill(T2);

    Cmd = makering2lp("RingShape", XUX, UX);
    execute(Cmd);

    ideal P_ext = imap(RingVar, varP);
    //これでPがK(A, UX)[XUX]へ拡大されたと考えられる。
    //n.b. ring RingShape = 0, (XUX, UX+A), (lp, lp);
    ideal G = groebner(P_ext);
    //［優先度低い］ほとんどの場合このGroebner基底がそのままShape formになるが、まれにそうでもなく、線形変換が必要になることがあり、対策を講じる必要である。
    //対応法として、[野呂・横山 - グレブナー基底の計算 基礎編]アルゴリズム4.9, 4.30などを参照されたい。Lex順序に関するGroebner基底がShape formでない場合、ランダムに線形変数変換を施した後、独立に最小多項式を求めて、そのminimal polynomialでShape formが求まる。ただしこの場合Groebner基底w.r.t.lpで一気に両方を出すことは無理である。
    list PQ_shape;
    poly f_shape;
    poly Xr = imap(RingAll, tempXr);

    for(i=1; i<=size(G); i++){
        if(variables(G[i])[1] != Xr){
            PQ_shape[size(PQ_shape)+1] = G[i];
        }else{
            f_shape = G[i];
        }
    }
    int flag = 0;
    if(size(PQ_shape)){
        flag = 1;
    }

    setring(RingVar);
    
    poly lcPlcQ = 1;
    if(flag){
        list PQ = imap(RingShape, PQ_shape);
    }else{
        list PQ = list();
    }
    poly f = imap(RingShape, f_shape);

    for(i=1; i<=size(PQ); i++){
        poly temptail = PQ[i]-lead(PQ[i]);
        if(temptail != 0){
            //そのままq_i == 0 になることもあるから、0がかけられたら困るのでIF文を入れる。
            lcPlcQ = lcPlcQ * leadcoef(temptail);
        }
    }
    lcPlcQ = lcPlcQ * leadcoef(f);

    poly lcH = imap(RingAll, lcH1) * imap(RingAll, lcH2);

    return(lcPlcQ, f, lcH);
}

proc paraprimdec(ideal F, list Paras, list Vars, list Indet, def RingVar, def RingAll){
    //イデアルFがRingVarの下で与えられたと仮定する。
    option(redSB);
    option(noredefine);
    int i, j;
    
    list Parameters = Paras;
    list Variables = Vars;
    list Indeterminates = Indet;
    poly VMinDPoly_var = Vars[size(Vars)];
    list Checks = 0, 0, 0, 0, 0, 0;

    export(Parameters, Variables, Indeterminates, VMinDPoly_var, Checks);
    export(RingVar, RingAll);

    list Z = list();

    ideal G = std(F);

    list PD = primdecSY(G);
    //list PD = primdecSYCI(G);
    ideal E = 0;
    list N = list();

    setring(RingAll);
    list Variables_all = imap(RingVar, Variables);
    list Parameters_all = imap(RingVar, Parameters);
    poly VMinDPoly = imap(RingVar, VMinDPoly_var);
    export(Variables_all, Parameters_all);
    export(VMinDPoly);

    ideal F_all = imap(RingVar, F);
    ideal G_all = imap(RingVar, G);
    
    //S \intersect K[A]の計算
    ideal S = quotient(F_all, G_all);

    list SA;
    int flag = 0;
    for (i=1; i<=size(S); i++){
        if(S[i]<VMinDPoly){
            SA[size(SA)+1] = S[i];
            flag = 1;
        }
    }
    //list J1：拡大されたPのShape formのパラメータ部分の積、list J2：Pの先頭係数積の計算、Of：K[A, X]上の既約多項式集合、efficient HITにて特化イデアルの準素判定に登場
    setring(RingVar);

    list J1, J2;
    list Of;
    for(i=1; i<=size(PD); i++){
        ideal Q = PD[i][1];
        ideal P = PD[i][2];
        poly h = 1;

        for(j=1; j<=size(Q); j++){
            h = h * leadcoef(Q[j]);
        }
        if(h != 1){
            N[size(N)+1] = h;
        }
        poly h = 1;
        for(j=1; j<=size(P); j++){
            h = h * leadcoef(P[j]);
        }
        if(h != 1){
            J2[size(J2)+1] = h;
        }
        J1[size(J1)+1], Of[size(Of)+1], N[size(N)+1] = ext_shape(Q, P);
    }

    //Conbine list SA_var, list J1, J2, list N={h1, ..., hm}, note that elements in {h1, ..., hm} + SA_var will be used in the next step of computing CGS. 
    if(flag){
        list SA_var = imap(RingAll, SA);
    }else{
        list SA_var = list();
    }

    for(i=1; i<=size(SA_var); i++){
        if(SA_var[i] != 1){
            N[size(N)+1] = SA_var[i];
        }
    }

    poly tempf = 1;
    for(i=1; i<=size(J1); i++){
        tempf = tempf * J1[i];
    }
    N[size(N)+1] = tempf;

    poly tempf = 1;
    for(i=1; i<=size(J2); i++){
        tempf = tempf * J2[i];
    }
    typeof(tempf);
    N[size(N)+1] = tempf;

    setring(RingAll);
    list old_N = imap(RingVar, N);
    ideal E_all = imap(RingVar, E);
    list new_N = Simplify_DisEqu(old_N, E_all);//KSW_CGSから借りた。Nに対するFactorizationの上にEを使って簡約させた。
    int flag2 = 0;
    if(!size(new_N)){
        flag2 = 1;
    }
    list cgsN = list();//後のCGS呼び出すで使う。ここで定義すればimapが一回減らせる。
    setring(RingVar);

    if(flag2){
        list N = list();
    }else{
        list N = imap(RingAll, new_N);
    }
    Z[size(Z)+1] = list(PD, E, N, Of);

    for(i=1; i<=size(N); i++){
        poly temph = N[i];
        setring(RingAll);
        ideal cgsE = imap(RingVar, temph);
        ideal cgsF = imap(RingVar, F);

        list CGS = idealcgs_main(cgsE, cgsN, cgsF);
        cgsN[size(cgsN)+1] = imap(RingVar, temph);
        if(size(CGS)){
            for(j=1; j<=size(CGS); j++){
                ideal tempG, tempE;
                list tempN;
                tempE, tempN, tempG = CGS[j][1],  CGS[j][2], CGS[j][3];
                if(size(tempN) == 0){
                    tempN = poly(1);
                }
                setring(RingVar);
                ideal ppdG, ppdE;
                list ppdN;
                ppdE, ppdN, ppdG = imap(RingAll, tempE), imap(RingAll, tempN), imap(RingAll, tempG);
                Z = Z + ppd_main(ppdE, ppdN, ppdG);
        
                setring(RingAll);
            }
        }
        setring(RingVar);
    }
    return(Z);
}

proc ppd_main(ideal E, list N, ideal G){
    int i, j;
    list Z = list();

    list PD = primdecSY(G);
    //list PD = primdecSYCI(G);
    if(size(PD)==1){//ゼロイデアルが出たら直ちにReturnさせる。
        poly zerocheck = PD[1][1][1];
        if(zerocheck == 0){
            Z[size(Z)+1] = list(PD, E, N, list(poly(1)));
            return(Z);
        }
    }

    setring(RingAll);

    ideal F_all = imap(RingVar, F);
    ideal G_all = imap(RingVar, G);
    
    ideal S = quotient(F_all, G_all);

    list SA;
    int flag = 0;
    for (i=1; i<=size(S); i++){
        if(S[i]<VMinDPoly){
            SA[size(SA)+1] = S[i];
            flag = 1;
        }
    }
    
    setring(RingVar);
    list J1, J2;
    list Of;

    for(i=1; i<=size(PD); i++){
        ideal Q = PD[i][1];
        ideal P = PD[i][2];
        poly h = 1;

        for(j=1; j<=size(Q); j++){
            h = h * leadcoef(Q[j]);
        }
        if(h != 1){
            N[size(N)+1] = h;
        }
        poly h = 1;
        for(j=1; j<=size(P); j++){
            h = h * leadcoef(P[j]);
        }
        if(h != 1){
            J2[size(J2)+1] = h;
        }
        J1[size(J1)+1], Of[size(Of)+1], N[size(N)+1] = ext_shape(Q, P);
    }

    if(flag){
        list SA_var = imap(RingAll, SA);
    }else{
        list SA_var = list();
    }

    for(i=1; i<=size(SA_var); i++){
        if(SA_var[i] != 1){
            N[size(N)+1] = SA_var[i];
        }
    }

    poly tempf = 1;
    for(i=1; i<=size(J1); i++){
        tempf = tempf * J1[i];
    }
    N[size(N)+1] = tempf;

    poly tempf = 1;
    for(i=1; i<=size(J2); i++){
        tempf = tempf * J2[i];
    }
    N[size(N)+1] = tempf;

    setring(RingAll);
    list old_N = imap(RingVar, N);
    ideal E_all = imap(RingVar, E);
    list new_N = Simplify_DisEqu(old_N, E_all);
    int empty_N = 0;
    if(size(new_N) == 0){
        empty_N = 1;
    }
    list cgsN = new_N;
    setring(RingVar);

    if(empty_N){
        list N = poly(1);
    }else{
        list N = imap(RingAll, new_N);
    }
    Z[size(Z)+1] = list(PD, E, N, Of);

    for(i=1; i<size(N); i++){
        poly temph = N[i];
        setring(RingAll);
        ideal cgsE = imap(RingVar, temph);
        ideal cgsF = imap(RingVar, F);

        list CGS = idealcgs_main(cgsE, cgsN, cgsF);
        cgsN[size(cgsN)+1] = imap(RingVar, temph);
        if(size(CGS)){
            for(j=1; j<=size(CGS); j++){
                ideal tempG, tempE;
                list tempN;
                tempE, tempN, tempG = CGS[j][1],  CGS[j][2], CGS[j][3];

                setring(RingVar);
                ideal ppdG, ppdE;
                list ppdN;
                ppdE, ppdN, ppdG = imap(RingAll, tempE), imap(RingAll, tempN), imap(RingAll, tempG);
                Z = Z + ppd_main(ppdE, ppdN, ppdG);
        
                setring(RingAll);
            }
        }
        setring(RingVar);
    }
    return(Z);
}

/////Codes for the Computation of Comprehensive Groebner Systems/////
static proc Radical_Equ(ideal Equ){
//From KSW. Eの元を因数分解して無平方化しただけ。できるだけ遅いとされる根基を避けている本アルゴリズムでは初手で根基を計算するわけがない。
    if (size(Equ) == 0){
        return(Equ);
  }
  ideal SqrEqu;
  list EquFactors;
  poly tempP;
  int i, j, flag;
  
  for (i = 1; i <= size(Equ); i++){
    
    EquFactors = factorize(Equ[i], 2);

    flag = 0;
    for (j = 1; j <= size(EquFactors[2]); j++){
      if (EquFactors[2][j] > 1){
        flag = 1;
        break;
      }
    }
    if (flag){
      tempP = 1;
      for (j = 1; j <= size(EquFactors[1]); j++){
        tempP = tempP * EquFactors[1][j];
      }
      SqrEqu = SqrEqu + tempP;
    }
  }

  if (size(SqrEqu)){
    return(std(Equ + SqrEqu));
  }
  else{
    return(Equ);
  }
}

static proc Simplify_DisEqu(list DisEqu, ideal Equ){
    //From KSW. Nを因数分解してEでそれらを簡約化した。Simplifyというより矛盾する条件を事前に取り除いている。
    list newDisEqu;
    ideal DisFactors;
    poly tempP;
    int i, j, k, flag;

    for (i = 1; i <= size(DisEqu); i++){
        DisFactors = factorize(DisEqu[i], 1);
        for (j = 1; j <= size(DisFactors); j++){
            if (size(Equ)){
                tempP = reduce(DisFactors[j], Equ);
            }else{
                tempP = DisFactors[j];
            }
            if (leadmonom(tempP) != 1){
                flag = 1;
                for (k = 1; k <= size(newDisEqu); k++){
                    if (newDisEqu[k] == tempP){
                        flag = 0;
                        break;
                    }
                }
                if (flag){
                    newDisEqu[size(newDisEqu)+1] = tempP;
                }
            }
        }
    }
    return(newDisEqu);
}

static proc Simplify_Equ(ideal Equ, list DisEqu){
    //From KSW. 余計にエラーを引き起こす可能性がある？？？：EをNの簡単な形を持つ元、i.e. 次数が3以下か単項式の数が5以下のもので簡約する。
    if (size(Equ) == 0){
        return(Equ);
    }
    if (Equ[1] == 1){
        return(Equ);
    }
    ideal newEqu, tempGB;
    int i, j;
    
    newEqu = Equ;

    for (i = 1; i <= size(DisEqu); i++){
        if ((deg(DisEqu[i]) > 3) || (size(DisEqu[i]) > 5)){
            i++;
            continue;
        }

        tempGB = std(newEqu + (DisEqu[i] * VMinDPoly - 1));
        if (tempGB[1] == 1){
            return(ideal(1)); //may incur error
        }

        newEqu = ideal();

        for (j = 1; j <= size(tempGB); j++){
            if (VMinDPoly > tempGB[j]){
                newEqu = newEqu + tempGB[j];
            }
        }
    }
    return(std(newEqu));
}

//Checks=[total, tri-check, 0dim-check, c-check, i-check, gen-check];
proc Check_Consistence(ideal Equ, list DisEqu){
    //From KSW. KSWアルゴリズムの真骨頂
    Checks[1] = Checks[1] + 1;
    //trivial checks
    if (!size(Equ)){
        Checks[2] = Checks[2] + 1;
        return(1);
    }
    if (Equ[1] == 1){
        Checks[2] = Checks[2] + 1;
        return(0);
    }
    if (!size(DisEqu)){
        Checks[2] = Checks[2] + 1;
        return(1);
    }
    //normal form
    poly DE = 1;
    int i, j;
    
    for (i = 1; i <= size(DisEqu); i++){
        DE = reduce(DE * DisEqu[i], Equ);
        if (DE == 0){
            //Nの一部がEに含まれることになるのでこの部分が必ず同時に「0になる」と「0にならない」ことが要求されて矛盾
            Checks[2] = Checks[2] + 1;
            return(0);
        }
    }
    //c-check
    int ctimes = 1;
    ideal LM;

    for (i = 1; i <= size(Equ); i++){
        LM = LM + leadmonom(Equ[i]);
    }
    LM = std(LM);
    intvec Indvec = indepSet(LM);
    
    list Indvar;
    for (i = size(Variables_all) + 1; i <= size(Indvec); i++){
        if (Indvec[i] != 0){
            Indvar = Indvar + list(Parameters_all[i - size(Variables_all)]);
        }
    }

    ideal tempGB, Spe;

    if (size(Indvar)){
        for (i = 1; i <= ctimes; i++){
            for (j = 1; j <= size(Indvar); j++){
                Spe = Spe + (Indvar[j] - random(-50, 50));
                //例えば(10, 20, 30)でパラメータ(a, b, c)を特化したいならば、イデアル<a-10, b-20, c-30>とEの和イデアルのGroebner基底を求めるといい。
            }
            
            tempGB = std(Equ + Spe + (DE * VMinDPoly - 1));

            if (tempGB[1] != 1){
                Checks[4] = Checks[4] + 1;
	        return(1);
            }
        }
    }
    //i-check
    int itimes = 3;
    poly newDE = DE;
    poly res, tempDE;
    tempGB = std(Equ);
    for (i = 1; i <= itimes; i++){
        if (size(newDE) > 20){
            break;
        }
        res = 0;
        tempDE = newDE;
        for (j = 1; j <= size(newDE); j++){
            res = res + reduce(lead(tempDE) * newDE, tempGB);
            tempDE = tempDE - lead(tempDE);
        }
        if (res == 0){
            Checks[5] = Checks[5] + 1;
            return(0);
        }
        newDE = res;
    }


  //general check
    tempGB = std(Equ + (DE * VMinDPoly - 1));
    if (tempGB[1] == 1){
        Checks[6] = Checks[6] + 1;
        return(0);
    }else{
        Checks[6] = Checks[6] + 1;
        return(1);
    }
}

proc idealcgs_main(ideal E, list N, ideal F){
    int i;
    ideal new_E = std(E);
    new_E = Radical_Equ(new_E);
    list new_N = Simplify_DisEqu(N, new_E);
    new_E = Simplify_Equ(new_E, new_N);
    //KSWのSによると、Simplify_Equがエラーを引き起こす可能性あるらしい。

    if (!Check_Consistence(new_E, new_N)){
        return(list());
    }

    ideal G = std(F + new_E);

    if (G[1] == 1){
        return(list(list(new_E, new_N, ideal(1))));
    }

    list Z = list();

    ideal GB, Gr;
    for(i = 1; i <= size(G); i++){
        if(G[i] >= VMinDPoly){
            GB[size(GB)+1] = G[i];
        }else{
            Gr[size(Gr)+1] = G[i];
        }
    }

    if (size(GB) == 0){
        return(list(list(new_E, new_N, ideal(0))));
    }

    if(Check_Consistence(new_E + Gr, new_N)){
        list tempN = new_N;
        for(i=1; i<=size(Gr); i++){
            tempN[size(tempN)+1] = Gr[i];
        }
        Z[size(Z)+1] = list(new_E, tempN, ideal(1));
    }
    if(!Check_Consistence(Gr, new_N)){
        return(Z);
    }

    ideal Gm;
    poly LCoefs;
    Gm, LCoefs = MDBasis(GB);
    list LCFactors;
    ideal tempLCFactors = factorize(LCoefs, 1);
    for(i=1; i<=size(tempLCFactors); i++){
        LCFactors[size(LCFactors)+1] = tempLCFactors[i];
    }

    new_E = new_E + Gr;

    if(Check_Consistence(new_E, new_N + LCFactors)){
        Z[size(Z)+1] = list(new_E, new_N + LCFactors, Gm);
    }

    list tempN = new_N;
    for(i = 1; i <= size(LCFactors); i++){
        ideal tempE = new_E;
        tempE[size(tempE)+1] = LCFactors[i];
        Z = Z + idealcgs_main(tempE, tempN, G);

        tempN[size(tempN)+1] = LCFactors[i];
    }
    return(Z);
}

proc MDBasis(G){
    int i, j, k, redundant;

    setring(RingVar);
    ideal G = imap(RingAll, G);
    poly LCoefs = 1;

    ideal lm_G;
    for(i=1; i<=size(G); i++){
        lm_G[size(lm_G)+1] = leadmonom(G[i]);
        LCoefs = LCoefs*leadcoef(G[i]);
    }

    setring(RingAll);
    ideal lm_G = imap(RingVar, lm_G);
    lm_G = std(lm_G);

    setring(RingVar);
    ideal lm_G = imap(RingAll, lm_G);

    ideal basis;
    for (i=1; i<=size(G); i++){
        for(j=1; j<=size(lm_G); j++){
            if(leadmonom(G[i]) == lm_G[j]){
                redundant = 0;
                for(k=1; k<=size(basis); k++){
                    if(leadmonom(basis[k]) == leadmonom(G[i])){
                        redundant = 1;
                        break;
                    }
                }
                if(redundant == 0){
                    basis[size(basis)+1] = G[i];
                }
            }
        }
    }
    setring(RingAll);
    return(imap(RingVar, basis), imap(RingVar, LCoefs));
}

proc finitefield_idealcgs_main(int q, ideal E, list N, ideal F){
    //K.Tanakaによる有限体上のCGS計算方法。Consistence Check以外は著しい変更はない。
    int i;
    ideal new_E = std(E);
    new_E = Radical_Equ(new_E);
    list new_N = Simplify_DisEqu(N, new_E);
    new_E = Simplify_Equ(new_E, new_N);

    if (!FF_Check_Consistence(q, new_E, new_N)){
        return(list());
    }

    ideal G = std(F + new_E);

    if (G[1] == 1){
        return(list(list(new_E, new_N, ideal(1))));
    }

    list Z = list();

    ideal GB, Gr;
    for(i = 1; i <= size(G); i++){
        if(G[i] > VMinDPoly){
            GB[size(GB)+1] = G[i];
        }else{
            Gr[size(Gr)+1] = G[i];
        }
    }

    if (size(GB) == 0){
        return(list(list(new_E, new_N, ideal(0))));
    }

    if(FF_Check_Consistence(q, new_E + Gr, N)){
        list tempN = new_N;
        for(i=1; i<=size(Gr); i++){
            tempN[size(tempN)+1] = Gr[i];
        }
        Z[size(Z)+1] = list(new_E, tempN, ideal(1));
    }
    if(!FF_Check_Consistence(q, Gr, new_N)){
        return(Z);
    }

    ideal Gm;
    poly LCoefs;
    Gm, LCoefs = MDBasis(GB);
    list LCFactors;
    ideal tempLCFactors = factorize(LCoefs, 1);
    for(i=1; i<=size(tempLCFactors); i++){
        LCFactors[size(LCFactors)+1] = tempLCFactors[i];
    }

    if(FF_Check_Consistence(q, new_E, new_N + LCFactors)){
        Z[size(Z)+1] = list(new_E, new_N + LCFactors, Gm);
    }

    list tempN = new_N;
    for(i = 1; i <= size(LCFactors); i++){
        ideal tempE = E;
        tempE[size(tempE)+1] = LCFactors[i];
        Z = Z + finitefield_idealcgs_main(q, tempE, tempN, G);
        tempN[size(tempN)+1] = LCFactors[i];
    }
    return(Z);
}

static proc FF_Check_Consistence(int q, ideal E, list N){
    //the basering shall be kept in RingAll.
    int i;
    if(!size(N) && reduce(poly(1), E)!=0){
        return(1);
    }
    ideal PHI;
    for(i=1; i<=size(Parameters); i++){
        poly tempU = Parameters[i];
        PHI[size(PHI)+1] = tempU^q - tempU;
    }

    ideal tempE = std(E + PHI);

    for(i=1; i<=size(N); i++){
        if(reduce(N[i], tempE) != 0){
            return(1);
        }
    }
    return(0);
}