LIB "primdec.lib";

// primdecSYCI
// saturatedSeparatingIdeal
// makeMinAss
// removeIdeal
// equalIdeal
// myextraction
// myminimal
// mysq
// mysat
// extraction2 (buggy)

proc primdecSYCI(ideal I,list #){
// [INPUT]
//  I : an input ideal
//  # : optional parameter
//    0,"Inc" or 1,"noInc"   -> whether incremental of ssi computation
//    "GTZ" or "Char"        -> an algorithm of minimal associated primes
//    "colon" or noColon"    -> whether using computation of colon
//    "nofacstd"             -> facstd is not used in minAssGTZ 
//    "minass"               -> compute only associated primes of ideal I
//    "Timer"                -> display a log of elapsed time
// [OUTPUT]
//  pd : a list pd of primary components and its associated primes
//       pd[i][1] : the i-th primary component
//       pd[i][2] : the i-th associated prime component

	option(redSB);	
	system("--ticks-per-sec",1000);
	timer = 0;
	int tt = timer;
	int t0,t1,t2,t3,t4,t5,t6,t7,tm;
	int i,j,k,l;
	string tmpOption;
	string dataname;

	intvec totalTimer= 0,0,0,0,0,0,0; 
	//[1]:minAss  [2]:Rij  [3]:SSI  [4]:Tij  [5]:colon  [6]:other  [7]:Total 
	
// default options
	int ssiType = 1;       // default is no incremental computaiton of ssi
	string algorithm        = "GTZ";
	string colonOption      = "noColon";
	string changeOrderLocal = "ext";
	int makeDataFlag = 0;
	int onlyMinass   = 0;
	int nofacstd     = 0;
	int timerOption  = 0;
// change options
	if(size(#) > 0){
		int valid;
		for(j = 1; j <= size(#); j++){
			valid = 0;
			if((typeof(#[j]) == "int") || (typeof(#[j]) == "number")){
				if((#[j] >= 0) || (#[j] <= 3)){ ssiType = #[j];   valid = 1;}
			}
			if(typeof(#[j]) == "string"){
				tmpOption = #[j];
				if((tmpOption == "Inc") || (tmpOption == "noInc")){
					if(tmpOption == "Inc"){	ssiType = 1; valid = 1; }
					if(tmpOption == "noInc"){ssiType = 0; valid = 1; }
				}if((tmpOption == "GTZ") || (tmpOption == "Char")){
					algorithm= tmpOption; valid = 1;
				}if((tmpOption == "noColon") || (tmpOption == "Colon")){
					colonOption = tmpOption; valid = 1;
				}if((tmpOption == "ext") || (tmpOption == "local")|| (tmpOption == "only")){
					changeOrderLocal = tmpOption; valid = 1;
				}if(string(tmpOption[1..4]) == "log="){
					makeDataFlag = 1; 
					dataname = tmpOption[5..size(tmpOption)]; valid = 1;
				}if(tmpOption == "minass"){
					onlyMinass = 1; valid = 1;
				}if(tmpOption == "nofacstd"){
					nofacstd = 1; valid = 1;
				}if(tmpOption == "Timer"){
					timerOption  = 1; valid = 1;
				}
			}
			if(valid == 0){
				dbprint(1,"Warning! The following input parameter was not recognized:",	tmpOption);
			}
		}
	}
	list minAssList = list();
	list addList = list();	
	list decompList = list();

	ideal Q = ideal(1);
	ideal Qi,Rij,Tij,J,Ci,Pi,Eij,Sij,Uij;
	ideal minAssJ,minAssL;	
	ideal RadI = 1;
	poly qi,fj,tl;

	int sizeMinAss,sizeMAL,sizeAss,sizeQ;
	int cnt = 1;
	intvec level;
	string tmp;
	ideal C = I;
	I = groebner(I);

	if ( dim(I)== 0 ) { return(primdecGTZ(I)); }
	while(1){
		t0 = timer;
		addList = list();
		if(cnt == 1){
			if(algorithm == "GTZ"){
				minAssList = minAssGTZ(C,nofacstd);
			}else{
				minAssList = minAssChar(C);
			}
			t1 = timer - t0;
			if(timerOption){ "minAss"+algorithm+" time: "+string(t1)+"ms";}
			sizeMinAss = size(minAssList);
		}else{
			if(colonOption == "Colon"){
				if(algorithm == "GTZ"){
					minAssList = minAssGTZ(C,nofacstd);
				}else{
					minAssList = minAssChar(C);
				}
			}else{
				minAssList = makeMinAss(Q,I,nofacstd,timerOption);
			}
			t1 = timer - t0;
			if(timerOption){ "minAss"+algorithm+" time: "+string(t1)+"ms"; }
			sizeMinAss = size(minAssList);
		}
		totalTimer[1] = totalTimer[1] + t1;
		if(timerOption){ "loop"+string(cnt)+": size"+string(sizeMinAss); }
		t0 = timer;
		Qi = 1;
		for(j = 1; j <= sizeMinAss; j++){
			minAssList[j] = std(minAssList[j]);
			if(cnt == 1){ RadI = std(intersect(RadI,minAssList[j])); }
		}
		if (cnt == 1){ RadI = groebner(RadI); }
		t6 = timer - t0; totalTimer[6] = totalTimer[6] + t6;
		for(j = 1; j <= sizeMinAss; j++){
			t0 = timer; tm = timer;
			minAssJ = minAssList[j];
			fj = 1;
			for(l = 1; l <= sizeMinAss; l++){
				if(j != l){
					minAssL = minAssList[l];
					sizeMAL = ncols(minAssL);
					for(k = 1; k <= sizeMAL; k++){
						tl = reduce(minAssL[k],minAssJ);
						if(tl != 0){
							fj = fj * minAssL[k];
							break;
						}
					}
				}
			}
			fj = mysq(fj);
			t6 = timer - t0; totalTimer[6] = totalTimer[6] + t6 ; t0 = timer;
			if(changeOrderLocal == "ext"){
				Sij = sat(I,fj)[1];
				Uij = myextraction(Sij,minAssJ);
				Rij = intersect(Q,Uij);
				Rij = groebner(Rij);
			}
			if(changeOrderLocal == "local"){
				Eij = myextraction(I,minAssJ);
				Sij = sat(Eij,fj)[1];
				Uij = intersect(Q,Sij);
				Rij = groebner(Uij);
			}
			if(changeOrderLocal == "only"){
				Rij = groebner(intersect(Q,sat(I,fj)[1]));
			}
			t2 = timer - t0; totalTimer[2] = totalTimer[2] + t2;
			if(!onlyMinass){
				t0 = timer;			
				J   = saturatedSeparatingIdeal(Rij,Q,minAssJ,RadI,ssiType,-1);
				t3 = timer - t0; totalTimer[3] = totalTimer[3] + t3; t0 = timer;	
				Tij = myextraction((Rij+J),minAssJ);
				t4 = timer - t0; totalTimer[4] = totalTimer[4] + t4; t0 = timer;
				Qi  = std(intersect(Qi,Rij));	
				addList = addList + list(list(Tij,minAssJ));
				t6 = timer - t0; totalTimer[6] = totalTimer[6] + t6;
			}else{
				Qi  = std(intersect(Qi,Rij)); addList = addList + list(minAssJ);
			}
			tm = timer - tm;
			if(timerOption){
				"miniloop: "+string(tm)+"ms (Rij:"+string(t2)+"ms ssi:"+string(t3)+"ms Tij:"+string(t4)+"ms)";
			}
		}
		if(timerOption){"--------------------------------------------------";}
		level[cnt] = size(addList);
		Q = groebner(intersect(Q,Qi));
		decompList = decompList + addList;
		if(size(reduce(Q,I)) == 0){	break; }
		if(colonOption == "Colon"){
			t0 = timer;
			C = groebner(quotient(I,Q));
			t5 = timer - t0;"Colon     time: "+string(t5)+"ms";
			totalTimer[5] = totalTimer[5] + t5;
		}
		cnt++;
	}

	tt = timer - tt; totalTimer[7] = tt;
	string ctimer = "time:"+ string(tt/1000) +".";
	if(tt%1000 < 100){
			ctimer = ctimer +"0"+string(tt%1000) +"sec ";
	}else{
			ctimer = ctimer + string(tt%1000) +"sec ";
	}
	if(timerOption){
		ctimer; totalTimer; level;
	}
	if(makeDataFlag){
		string ret1 = "Comp: "+string(level);
		string ret2 = "OPTIONS: ";
		string logfile = "./log/pd_log"+dataname;
		string timerstr= "(minAss,Rij,SSI,Tij,Colon,Other,Total)=";
		ret2 = ret2 +string(ssiType)+","+algorithm+",";
		ret2 = ret2 +colonOption+","+changeOrderLocal;
		if(onlyMinass){ ret2 = ret2 + " mode:minAss"; }
		timerstr = timerstr + "("+string(totalTimer) + ")";
		string ret3 = ctimer + timerstr;

		write(":a "+logfile,ret1,ret2,ret3);
	}
	return(decompList);
}

proc saturatedSeparatingIdeal(ideal I, ideal Q, ideal C, ideal radI, int ssiType, int opt){
// [INPUT]
//	I      : input ideal
//	Q      : an intersection of known primary components of I
//	C      : ideal C satisfying \sqrt{C} = \sqrt{I:Q} 
//	radI   : radical ideal of I
//	ssiType: select ssi algorithm
//          0 -> incremental version
//          1 -> usual intersection version
//          2,3 -> another intersection version
//	opt    : whether using algorithm for reduceing some generator
//          0 -> NO use
//          1 -> use 
// [OUTPUT]
//	S0     : a generating set of saturated separating ideal for(I,Q)

	def BASE = basering;
	I = groebner(I);C = groebner(C);
	
	poly CI;	
	int sizeC = size(C);
	int i,j,k;
	ideal H = 0;
	for(i = 1; i <= sizeC; i++){
		CI = C[i];
		if(size(reduce(CI,radI)) != 0){ H = H+CI; }
	}
	int sizeH = size(H);
	poly HI;
	ideal S = ideal(0);
	ideal S0= ideal(0);
	intvec expS0;
	int cntExp;
	string runlog="";

/// pre-process Alog 8
	if(opt == 1){
		poly fj;
		ideal T = radI;
		ideal T0;
		for(j = 1; j <= sizeH; j++){
			fj = H[j];
			T0 = groebner(radical(I+ideal(S+fj)));
			if(size(reduce(T0,T)) != 0){
				T = T0;
				S = S + fj;
			}
		}
		H = S; sizeH = size(H);
	}

	if(ssiType == 0){
		string tVar ="@t";
		int sizeVar = nvars(basering);
		for(i = 1; i <= sizeVar; i++){
			tVar = tVar + "," + varstr(i);
		}
		execute("ring RELIM = 
		("+charstr(basering)+"),("+tVar+"),(dp(1),dp("+string(sizeVar)+"));");
		def ELIM = basering;
		ideal G1,G2;
		ideal G = groebner((1-@t)*imap(BASE,Q) + @t*imap(BASE,I));

		poly f;
		setring BASE;
		poly f0,f;
		ideal G1,G2;
		for(i = 1; i<= sizeH; i++){
			f0 = H[i];
			f  = f0;
			setring ELIM;
			while(1){
				f = imap(BASE,f);
				G1= groebner(G+@t*f);
				G2 = eliminate(G1,@t);
				setring BASE;
				G2 = imap(ELIM,G2);
				if(size(reduce(G2,I)) == 0){
					setring ELIM;
					G = G1;
					setring BASE;
					S0 = S0 + f;
					break;
				}else{
					f = reduce(f * f0,I);
				}
				setring ELIM;		
			}
		}
	}
	if(ssiType == 1){
		for(i = 1; i <= sizeH; i++){
			HI = 1; cntExp = 1;
			while(1){
				HI = HI * H[i];
				if(size(reduce(intersect((I+ideal(S0+HI)),Q),I)) == 0){
					S0 = S0 + HI;
					expS0[i] = cntExp;
					break;
				}
				cntExp++;
			}
		}
	}	
	if(ssiType == 2){
		for(i = 1; i <= sizeH; i++){		
			HI = 1;cntExp = 1;
			while(1){
				HI = HI * H[i];
				if(size(reduce(intersect(I+ideal(HI),Q),I)) == 0){ break; }
				cntExp++;
			}
			
			if(size(reduce(intersect((I+ideal(S0+HI)),Q),I)) == 0){
				S0 = S0 + HI;
				expS0[i] = cntExp;
			}else{
				while(1){
					HI = HI * H[i];
					if(size(reduce(intersect((I+ideal(S0+HI)),Q),I)) == 0){
						S0 = S0 + HI;
						expS0[i] = cntExp;
						break;
					}
					cntExp++;
				}
			}
		}
	}
	if(ssiType == 3){
		S0 = H; cntExp = 1;
		while(1){
			if(size(reduce(intersect(I+S0,Q),I)) == 0){	break;}
			for(i = 1; i <= sizeH; i++){
				S0[i] = S0[i] * H[i];
			}cntExp++;
		}
		for(i = 1; i <= sizeH; i++){
			expS0[i] = cntExp;
		}
	}
	return(S0);
}

proc makeMinAss(ideal Q,ideal I,int nofacstd,list #){
// [INPUT]
//	Q	: a primary ideal
//	I	: an input ideal
//  #   : option  1 -> display a log of run
// [OUTPUT]
//	minAssList: a list of minimal associated primes
	list assList = list();
	list minAssList = list();
	
	ideal Ci,Pi;

	poly qi;	
	int sizeQ = size(Q);
	int sizeAss = size(assList);
	int i,j;
	int cnt=0;

	list quotList = list();
	int sizeQuot;
	
	int timerOption = 0;
	string tmp;
	if(size(#) > 0){
		int valid;
		for(j = 1; j <= size(#); j++){
			valid = 0;
			if((typeof(#[j]) == "int") || (typeof(#[j]) == "number")){
				timerOption = #[j];   valid = 1;
			}
			if(valid == 0){
				dbprint(1,"Warning! The following input parameter was not recognized:",tmpOption);
			}
		}
	}

	for(i = 1; i <= sizeQ; i++){
		qi = Q[i];
		if(size(reduce(qi,I)) != 0){
			quotList = quotList + list(quotient(I,qi));
		}				
	}
	tmp = "remove Quotient: "+string(size(quotList))+" -> ";
	quotList = removeIdeal(quotList);
	sizeQuot = size(quotList);
	tmp = tmp + string(sizeQuot);
	if(timerOption){ tmp; }
	for(i = 1; i <= sizeQuot; i++){
		assList = assList + minAssGTZ(quotList[i],nofacstd);
	}
	tmp = "make minAss: "+string(size(assList))+" -> ";
	minAssList = removeIdeal(assList);
	tmp = tmp + string(size(minAssList));
	if(timerOption){ tmp; }
	return(minAssList);
}

proc removeIdeal(list oldList){
// [INPUT]
//	oldList: a list of ideal
// [OUTPUT]
//	newList: a list of removing irredundant ideal 

	list newList = list();
	
	int sizeOld = size(oldList);
	int i,j;
	intvec rmVect;
	ideal Pi;
	for(i = 1; i <= sizeOld; i++){
		oldList[i] = std(oldList[i]); rmVect[i] = 0;
	}
	for(i = 1; i <= sizeOld; i++){
		if(!rmVect[i]){
			Pi = oldList[i];
			for(j = 1; j <= sizeOld; j++){
				if(j != i){
					if(!rmVect[j]){
						if(equalIdeal(Pi,oldList[j])){
							rmVect[j] = 1;
						}else{
							if(size(reduce(Pi,oldList[j])) == 0){
								rmVect[j] = 1;
							}
						}
					}
				}
			}
		}
	}
	for(i = 1; i <= sizeOld; i++){
		if(!rmVect[i]){	newList = newList + list(oldList[i]); }
	}
	return(newList);
}

proc equalIdeal(ideal L1,ideal L2){
	int i,j;
	int sizeL1 = size(L1);
	int sizeL2 = size(L2);
	poly f1;
	if(sizeL1 != sizeL2){ return(0); }
	for(i = 1; i <= sizeL1; i++){
		f1 = L1[i];
		for(j = 1; j<=sizeL2; j++){
			if(f1 == L2[j]){ break;	}
		}
		if(j>sizeL2){ return(0); }
	} 
	return(1);
}

proc mysq(poly p)
{
  ideal fac=factorize(p,1);       //the irreducible factors of p
  fac=sort(fac)[1];
  int i;
  poly f0=1;
  for(i=ncols(fac);i>=1;i--)
  {
      f0=f0*fac[i];
  }
  return (f0);
}

proc mysat (ideal i,poly f)
{
  def BR=basering;
  execute("ring ER=("+charstr(basering)+"),(@T,"+varstr(basering)+"),
  	(dp(1),"+ordstr(basering)+");");
  ideal I=(ideal(imap(BR,i))+ideal(1-@T*imap(BR,f)));
  I = std(I);
  I = nselect(I,1);
  setring BR;
  return(imap(ER,I));
}

proc myminimal(ideal I) {
	int i,j,sizeI;
	poly qi;
	ideal qid;

	sizeI = size(I);
	for ( i=1; i<=sizeI; i++ ) {
		qi = I[i];
		if ( qi != 0 ) {
			qid = leadmonom(qi);
			for ( j=1; j <=sizeI; j++ ) {
				if ( j != i && I[j] != 0 && reduce(leadmonom(I[j]),qid) == 0 ) {
					I[j] = 0;
				}
			}
		}
	}
	I=simplify(I,2);
	sizeI = size(I);
	for ( i=1; i<=sizeI; i++ ) {
		I[i] = cleardenom(simplify(I[i],1));
	}
	for ( i=1; i<=sizeI; i++ ) {
		qi = I[i];
		I[i] = 0;
		attrib(I,"isSB",1);
		I[i] = cleardenom(simplify(reduce(qi,I),1));
	}
	return (I);
}

proc myextraction(ideal Q, ideal P){
	def BASE = basering;

	intvec U = indepSet(P);
	if(size(ideal(U)) == 0){
		return(Q);
	}

	int i;
	int sizeU = size(U);
	string indepVar = "";
	string depVar = "";
	string invblkVar;
	int cnt = 0;

	for(i = 1; i <= sizeU; i++){
		if(U[i] == 1){
			indepVar = indepVar + varstr(i) + ",";
		}else{
			depVar = depVar + varstr(i) + ",";
			cnt++;
		}
	}
	indepVar = indepVar[1..size(indepVar)-1];
	depVar = depVar[1..size(depVar)-1];
	invblkVar = depVar + "," + indepVar;

	poly f = 1;
	poly g;

	//declare ring RINVBLK wrt inverse block order on  U >> X\U
	execute("ring RINVBLK =("+charstr(basering)+"),("+invblkVar+"),(dp("+string(cnt)+"),dp);");

	def IBLK = basering;
    //GB of Q in K[X] wrt inverse block order on U >> X\U
	ideal Q = groebner(imap(BASE,Q));
	poly f = 1;
	poly g;

	//declare quotient ring RQUOT
	execute("ring RQUOT = ("+charstr(basering)+","+indepVar+"),("+depVar+"),dp;");
	def QUOT = basering;
	ideal Qq = imap(IBLK,Q);
	kill IBLK;
	Qq = myminimal(Qq);

	poly g;
	int sizeQq = size(Qq);	
	for(i = 1; i <= sizeQq; i++){
		if ( Qq[i] != 0 ) {
	      g = leadcoef(Qq[i]);
	      setring BASE;
	      g = mysq(imap(QUOT,g));
	      f = (g / gcd(f,g)) * f; 
	      setring QUOT;
		}
	} 
	setring BASE;
	f = mysq(f);
	ideal Qiso = sat(imap(QUOT,Qq),f)[1];
	kill QUOT;
	return(Qiso);
}

// std over rational function fields seems to be broken.
// use myextract instead of extraction2.

proc extraction2(ideal Q, ideal P, list #){
// [INPUT]
//	Q	: a pseudo-primary ideal
//	P	: a prime ideal associated with Q
//	#	: option
// [OUTPUT]
//	list ret : a pair of primary ideal Qiso and remaining ideal Irem
//		  ret[1] = Qiso
//		  ret[2] = Irem

	def BASE = basering;

	intvec U = indepSet(P);
	if(size(ideal(U)) == 0){
		list ret = Q,ideal(1);   
		return(ret);
	}

// default option
	int computeDirectly = 1;
// change options
	if(size(#) > 0){
		int valid;
		for(j = 1; j <= size(#); j++){
			valid = 0;
			if((typeof(#[j]) == "int") || (typeof(#[j]) == "number")){
				if(#[j] == 1){ computeDirectly = #[j];   valid = 1;}
				if(#[j] == 0){ computeDirectly = #[j];   valid = 1;}
			}
			if(valid == 0){
				dbprint(1,"Warning! The following input parameter was not recognized:",tmpOption);
			}
		}
	}

	int i;
	int sizeU = size(U);
	string indepVar = "";
	string depVar = "";
	string invblkVar;
	int cnt = 0;

	for(i = 1; i <= sizeU; i++){
		if(U[i] == 1){
			indepVar = indepVar + varstr(i) + ",";
		}else{
			depVar = depVar + varstr(i) + ",";
			cnt++;
		}
	}
	indepVar = indepVar[1..size(indepVar)-1];
	depVar = depVar[1..size(depVar)-1];
	invblkVar = depVar + "," + indepVar;

	poly f = 1;
	poly g;

	if(computeDirectly){
		execute("ring RQUOT = ("+charstr(basering)+","+indepVar+"),("+depVar+"),dp;");
		def QUOT = basering;
		ideal Qq = groebner(imap(BASE,Q));
	}else{
		//declare ring RINVBLK wrt inverse block order on  U >> X\U
		execute("ring RINVBLK =("+charstr(basering)+"),("+invblkVar+"),(dp("+string(cnt)+"),dp);");

		def IBLK = basering;
	    //GB of Q in K[X] wrt inverse block order on U >> X\U
		ideal Q = groebner(imap(BASE,Q));
		poly f = 1;
		poly g;

		//declare quotient ring RQUOT
		execute("ring RQUOT = ("+charstr(basering)+","+indepVar+"),("+depVar+"),dp;");
		def QUOT = basering;
		ideal Qq = imap(IBLK,Q);  // Qq views as GB of Q in K(U)[X\U]
		kill IBLK;
	}
	int sizeQq = size(Qq);	

	poly g;
	for(i = 1; i <= sizeQq; i++){
	      g = leadcoef(Qq[i]);
	      setring BASE;
	      g = imap(QUOT,g);
	      f = (g / gcd(f,g)) * f; 
	      setring QUOT;
	} 
	setring BASE;
	
	Q = groebner(imap(QUOT,Qq));
	
	list SAT = sat(Q,f);
	ideal Qiso = SAT[1];  
	f = f ^ SAT[2];
	ideal Irem = Q + f;

	kill QUOT;
	list ret = Qiso,Irem;
	return(ret);
}
;
;